{
  "name": "ohday",
  "version": "1.0.0",
  "description": "Chainable, immutable, lightweight date/time processing library",
  "author": "Twisuki",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./plugins/*": "./dist/plugins/*"
  },
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "check": "tsc --noEmit",
    "build": "pnpm -w lint && pnpm check && pnpm test:run && tsup",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:run": "vitest run"
  },
  "devDependencies": {
    "@vitest/ui": "^4.1.9",
    "dayjs": "^1.11.21",
    "tsup": "^8.5.1",
    "typescript": "^6.0.0",
    "vitest": "^4.1.9"
  }
}
