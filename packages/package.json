{
  "name": "@twisuki/ohday",
  "version": "1.0.2",
  "description": "Chainable, immutable, lightweight date/time processing library",
  "author": "Twisuki",
  "publishConfig": {
    "access": "public"
  },
  "license": "MIT",
  "readme": "README.md",
  "repository": {
    "type": "git",
    "url": "https://github.com/Twisuki/ohday"
  },
  "bugs": "https://github.com/Twisuki/ohday/issues",
  "keywords": [
    "date",
    "time",
    "ohday",
    "immutable",
    "chainable",
    "lightweight"
  ],
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./plugins/*": "./dist/plugins/*"
  },
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "files": [
    "LICENSE",
    "README.md",
    "dist"
  ],
  "scripts": {
    "check": "tsc --noEmit",
    "build": "pnpm -w lint && pnpm check && pnpm test:run && tsup",
    "test": "cross-env TZ=Asia/Shanghai vitest",
    "test:ui": "pnpm test --ui",
    "test:run": "pnpm test run",
    "copy:readme": "node -e \"require('fs').copyFileSync('../README.md', './README.md')\"",
    "copy:license": "node -e \"require('fs').copyFileSync('../LICENSE', './LICENSE')\"",
    "copy": "pnpm copy:readme && pnpm copy:license",
    "remove:readme": "node -e \"const fs=require('fs');if(fs.existsSync('./README.md')) fs.unlinkSync('./README.md')\"",
    "remove:license": "node -e \"const fs=require('fs');if(fs.existsSync('./LICENSE')) fs.unlinkSync('./LICENSE')\"",
    "prepack": "pnpm build && pnpm copy",
    "postpack": "pnpm remove:readme && pnpm remove:license"
  },
  "devDependencies": {
    "@vitest/ui": "^4.1.9",
    "cross-env": "^7.0.3",
    "dayjs": "^1.11.21",
    "tsup": "^8.5.1",
    "typescript": "^6.0.0",
    "vitest": "^4.1.9"
  }
}
