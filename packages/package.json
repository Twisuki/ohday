{
  "name": "ohday",
  "version": "1.0.0",
  "description": "Chainable, immutable, lightweight date/time processing library",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./plugins/*": "./dist/plugins/*"
  },
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "sideEffects": false,
  "author": "Twisuki",
  "files": [
    "dist"
  ],
  "scripts": {
    "check": "tsc --noEmit",
    "build": "tsup"
  },
  "devDependencies": {
    "tsup": "^8.5.1",
    "typescript": "^6.0.0"
  }
}
